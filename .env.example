# Copia questo file in `.env` e inserisci la tua chiave API Google Gemini.
# Chiave GRATUITA da Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# (opzionale) modello da usare per qualificazione e report
GEMINI_MODEL=gemini-2.5-flash

# Database — in LOCALE lascia vuoto: usa un file SQLite (data/leadpilot.db).
# In PRODUZIONE (Vercel) imposta queste due variabili con i dati di Turso
# (https://turso.tech — piano gratuito):
# TURSO_DATABASE_URL=libsql://nome-db-utente.turso.io
# TURSO_AUTH_TOKEN=...
